{
  "manifest_version": 3,
  "name": "ETHZ Auto-Login",
  "version": "3.1",
  "description": "Automatically continues ETHZ login flows with browser-saved passwords or opt-in stored credentials",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.ethz.ch/*",
    "*://wayf.switch.ch/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.ethz.ch/*"],
      "js": ["logout-watch.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "*://aai-logon.ethz.ch/*",
        "*://gitlab.inf.ethz.ch/*",
        "*://*.ethz.ch/*/auth/shibboleth/login.php*",
        "*://*.ethz.ch/*/Shibboleth.sso/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://wayf.switch.ch/*"],
      "js": ["wayf.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png",
    "256": "icons/icon256.png"
  }
}
